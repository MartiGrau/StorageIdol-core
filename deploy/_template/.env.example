# StorageIdol Client Environment Variables
# Copy this file to .env and fill in all values
# This file lives on the client's server — it is the ONLY client-managed file

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=storageidol
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=storageidol

# ── Langfuse database (separate Postgres instance inside this stack) ───────────
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=<strong-random-password>
LANGFUSE_POSTGRES_DB=langfuse

# ── Docker Registry ───────────────────────────────────────────────────────────
REGISTRY_USER=<provided-by-storageidol>
REGISTRY_PASS=<provided-by-storageidol>

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=<from-meta-business-manager>
WHATSAPP_BUSINESS_ACCOUNT_ID=<from-meta-business-manager>
WHATSAPP_ACCESS_TOKEN=<from-meta-business-manager>
WHATSAPP_VERIFY_TOKEN=<random-string-you-choose>

# ── Voice: LiveKit (agent runtime) + Telnyx (Spanish +34 SIP trunk) ──────────
# LiveKit runs the STT→LLM→TTS pipeline. Telnyx provides Spanish phone numbers
# and routes PSTN calls to LiveKit via SIP (LiveKit native SIP does not provision ES DIDs).
LIVEKIT_URL=<wss://your-livekit-server>
LIVEKIT_API_KEY=<from-livekit-dashboard>
LIVEKIT_API_SECRET=<from-livekit-dashboard>
TELNYX_API_KEY=<from-telnyx-portal>
TELNYX_SIP_CONNECTION_ID=<from-telnyx-portal>
DEEPGRAM_API_KEY=<from-deepgram-console>
ELEVENLABS_API_KEY=<from-elevenlabs-console>

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<from-anthropic-console>

# ── Observability (Langfuse sidecar — auto-configured by provision-client) ────
LANGFUSE_PUBLIC_KEY=<auto-generated-run-langfuse-init>
LANGFUSE_SECRET_KEY=<auto-generated-run-langfuse-init>
LANGFUSE_HOST=http://langfuse:3000

# ── Client CRM (filled by StorageIdol during onboarding) ─────────────────────
CRM_BASE_URL=<your-api-base-url>
CRM_API_KEY=<your-api-key>

# ── Watchdog ──────────────────────────────────────────────────────────────────
WATCHDOG_OPS_TOKEN=<provided-by-storageidol>

# ── Payment (optional, for debt collection module) ────────────────────────────
# STRIPE_SECRET_KEY=<from-stripe-dashboard>
# STRIPE_PAYMENT_LINK_PRICE_ID=<from-stripe-dashboard>
# REDSYS_MERCHANT_CODE=<your-redsys-merchant-code>
# REDSYS_SECRET_KEY=<your-redsys-secret>
